<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1" author="datmacay_v1">
        <createTable tableName="users">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" />
            </column>
            <column name="username" type="varchar(255)"/>
            <column name="password" type="varchar(255)"/>
            <column name="email" type="varchar(255)"/>
            <column name="phone" type="varchar(255)"/>
            <column name="address" type="varchar(255)"/>
            <column name="fullname" type="varchar(255)"/>
            <column name="avatar_asset_id" type="varchar(255)"/>
            <column name="created_at" type="timestamp"/>
            <column name="updated_at" type="timestamp"/>
            <column name="created_by" type="bigint"/>
            <column name="updated_by" type="bigint"/>
            <column name="account_non_locked" type="TINYINT(1)"/>
            <column name="enabled" type="TINYINT(1)"/>
            <column name="role" type="VARCHAR(20)"/>
            <column name="is_account_non_expired" type="TINYINT(1)"/>
            <column name="is_credentials_non_expired" type="TINYINT(1)"/>
            <column name="failed_login_attempts" type="int"/>
            <column name="last_time_change_password" type="timestamp"/>
            <column name="lock_time" type="timestamp"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="users"
                baseColumnNames="avatar_asset_id"
                referencedTableName="media_asset"
                referencedColumnNames="id"
                constraintName="fk_users_media_asset"/>
    </changeSet>

</databaseChangeLog>